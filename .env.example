# Base URL for the application under test
BASE_URL=http://localhost:3000

# API base URL if different from BASE_URL
API_URL=http://localhost:3000

# Auth token for API requests
API_TOKEN=

# Test user credentials (for E2E login flows)
TEST_USER_EMAIL=user@example.com
TEST_USER_PASSWORD=password

# Absolute path to the campaign folder (used by globalSetup/globalTeardown for cleanup)
CAMPAIGN_DIR=C:/Users/your-user/demtol/campaigns/example

# Set to "true" in CI environments
CI=
